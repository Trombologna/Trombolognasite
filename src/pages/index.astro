---
import SatireLayout from "../layouts/SatireLayout.astro";
const posts = await Astro.glob("../../content/news/*.md");
---
<SatireLayout title="Benvenuti su TromBologna" description="Satira, meme e notizie sui cantieri del tram di Bologna.">
  <h2 class="text-2xl font-semibold mb-4">Ultime dal cantiere</h2>
  <ul class="list-disc pl-5 space-y-2">
    {posts.sort((a, b) => new Date(b.frontmatter.pubDate) - new Date(a.frontmatter.pubDate)).map(post => (
      <li><a href={post.url}>{post.frontmatter.title}</a> – {new Date(post.frontmatter.pubDate).toLocaleDateString("it-IT")}</li>
    ))}
  </ul>

  <h2 class="text-2xl font-semibold mb-4 mt-8">Cartoon del giorno</h2>
  <img src="/assets/cartoons/cartoon1.png" alt="Satirical cartoon of tram chaos" class="rounded-lg shadow" />
</SatireLayout>
